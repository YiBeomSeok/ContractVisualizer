<idea-plugin>
    <id>org.bmsk.contractvisualizer</id>
    <name>Contract Visualizer</name>
    <vendor>bmsk</vendor>
    <description>Visualizes MVI Contract files as Mermaid diagrams</description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true" supportsK1="true" />
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <fileEditorProvider
            implementation="org.bmsk.contractvisualizer.editor.ContractFileEditorProvider" />
    </extensions>
</idea-plugin>
